#!/bin/bash -x
#SBATCH --time=00:30:00
#SBATCH --export=ALL

module purge
module load compiler/gnu
module load mpi/openmpi/5.0-nvidia-25.1-nompi
module load toolkit/nvidia-hpc-sdk/25.1-nompi

echo "Running on ${SLURM_JOB_NUM_NODES} nodes with ${SLURM_NTASKS} total tasks."

# Execute passing through all arguments supplied by the scheduler
time mpirun /home/fr/fr_fr/fr_tw313/Hochleistungsrechnen/build/Release/benchmark "$@"
